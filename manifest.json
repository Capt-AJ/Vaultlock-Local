{
  "manifest_version": 3,
  "name": "VaultLock Local",
  "description": "An offline encrypted password vault for Chromium-based browsers.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "VaultLock Local",
    "default_popup": "panel.html",
    "default_icon": {
      "16": "icons/vault-16.png",
      "48": "icons/vault-48.png",
      "128": "icons/vault-128.png"
    }
  },
  "icons": {
    "16": "icons/vault-16.png",
    "48": "icons/vault-48.png",
    "128": "icons/vault-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-autofill.js"],
      "run_at": "document_idle"
    }
  ]
}
